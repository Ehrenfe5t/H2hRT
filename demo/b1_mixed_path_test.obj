# B1 mixed path test: box room with partition wedge
# Room: 6m(x) x 4m(y) x 3m(z)
# Partition at x=3 from z=0 to z=1.8 (wedge at top edge)

o room
v 0.0 0.0 0.0
v 6.0 0.0 0.0
v 6.0 4.0 0.0
v 0.0 4.0 0.0
v 0.0 0.0 3.0
v 6.0 0.0 3.0
v 6.0 4.0 3.0
v 0.0 4.0 3.0

o partition
v 3.0 0.0 0.0
v 3.0 0.0 1.8
v 3.0 4.0 1.8
v 3.0 4.0 0.0

vn 0.0 0.0 -1.0
vn 0.0 0.0 1.0
vn 0.0 -1.0 0.0
vn 0.0 1.0 0.0
vn -1.0 0.0 0.0
vn 1.0 0.0 0.0

# floor (z=0, normal down)
f 1//1 3//1 2//1
f 1//1 4//1 3//1
# ceiling (z=3, normal up)
f 5//2 6//2 7//2
f 5//2 7//2 8//2
# south wall (y=0, normal -y)
f 1//3 5//3 6//3
f 1//3 6//3 2//3
# north wall (y=4, normal +y)
f 4//4 7//4 8//4
f 4//4 3//4 7//4
# west wall (x=0, normal -x)
f 1//5 8//5 5//5
f 1//5 4//5 8//5
# east wall (x=6, normal +x)
f 2//6 7//6 3//6
f 2//6 6//6 7//6
# partition (x=3, faces east, normal +x)
f 9//6 11//6 10//6
f 9//6 12//6 11//6
