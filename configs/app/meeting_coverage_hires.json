{
  "app_runtime": {
    "mode": "debug",
    "log_level": "INFO",
    "run_id": "meeting-cov-hires"
  },
  "scene_import": {
    "source_file": "demo/meeting.obj",
    "source_format": "obj",
    "scene_material_map_file": "configs/scenes/scene_material_map.json"
  },
  "scene_preprocess": {
    "enable_wedge_build": true,
    "enable_scene_cache": false,
    "bvh_leaf_size": 16
  },
  "material": {
    "material_database_file": "demo/ItuMaterial.csv"
  },
  "antenna": {
    "source_type": "Ideal"
  },
  "path_search": {
    "max_path_depth": 10,
    "max_reflection_count": 4,
    "max_transmission_count": 4,
    "max_diffraction_count": 2,
    "enable_los": true,
    "tx_x": 16.0,
    "tx_y": 1.5,
    "tx_z": -12.0,
    "rx_x": 10.0,
    "rx_y": 1.5,
    "rx_z": -10.0
  },
  "sbr": {
    "enabled": true,
    "ray_count": 2000000,
    "max_ray_depth": 8,
    "max_reflection_count": 4,
    "max_transmission_count": 2,
    "max_diffraction_count": 1,
    "ray_power_threshold_dB": -40,
    "auto_grid_bounds": false,
    "rx_grid_min_x": 0.0,
    "rx_grid_max_x": 20.0,
    "rx_grid_min_y": 0.0,
    "rx_grid_max_y": 3.0,
    "rx_grid_min_z": -20.0,
    "rx_grid_max_z": 0.0,
    "rx_grid_step_x": 0.1,
    "rx_grid_step_y": 0.1,
    "rx_grid_step_z": 0.1,
    "rx_sphere_radius_m": 0.15,
    "tx_power_dBm": 0,
    "store_paths": false,
    "wedge_max_distance_m": 3.0,
    "wedge_max_candidates": 8
  },
  "em_solver": {
    "frequency_hz": 2400000000.0,
    "solver_mode": "Coverage"
  },
  "output": {
    "export_paths": true,
    "export_config_snapshot": false
  },
  "numeric_tolerance": {
    "eps_length": 1e-06,
    "eps_intersection": 1e-07,
    "eps_deduplicate": 1e-05,
    "self_hit_ignore_distance": 1e-05,
    "visibility_origin_offset": 1e-05,
    "visibility_target_shrink": 1e-05
  }
}
