{
  "app_runtime": {
    "mode": "debug",
    "log_level": "INFO",
    "enable_console_logging": true,
    "enable_file_logging": true,
    "log_file_path": "output/logs/rt.log",
    "config_snapshot_directory": "output/config_snapshots",
    "cache_directory": "output/cache",
    "run_id": "meeting-cov-hires"
  },

  "scene_import": {
    "source_file": "demo/meeting.obj",
    "source_format": "obj",
    "coordinate_transform": "blender_z_up_to_y_up",
    "scene_material_map_file": "configs/scenes/scene_material_map.json",
    "normalize_object_names": true
  },

  "scene_preprocess": {
    "rebuild_normals": false,
    "enable_wedge_build": true,
    "enable_scene_cache": false,
    "bvh_leaf_size": 16
  },

  "material": {
    "material_database_file": "demo/ItuMaterial.csv"
  },

  "antenna": {
    "source_type": "Ideal",
    "pattern_file": "",
    "polarization_file": "",
    "forward_x": 1.0, "forward_y": 0.0, "forward_z": 0.0,
    "up_x": 0.0, "up_y": 0.0, "up_z": 1.0
  },

  "path_search": {
    "max_path_depth": 10,
    "max_reflection_count": 4,
    "max_transmission_count": 4,
    "max_diffraction_count": 2,
    "max_scattering_count": 0,
    "enable_los": true,
    "max_consecutive_same_interaction": 5,
    "tx_x": 16.0, "tx_y": 1.5, "tx_z": -12.0,
    "rx_x": 10.0, "rx_y": 1.5, "rx_z": -10.0
  },

  "sbr": {
    "enabled": true,
    "ray_count": 2000000,
    "max_ray_depth": 8,
    "max_reflection_count": 4,
    "max_transmission_count": 2,
    "max_diffraction_count": 1,
    "ray_power_threshold_dB": -40.0,
    "rx_sphere_radius_m": 0.15,
    "auto_grid_bounds": false,
    "rx_grid_min_x": 0.0,
    "rx_grid_max_x": 20.0,
    "rx_grid_min_y": 1.4,
    "rx_grid_max_y": 1.5,
    "rx_grid_min_z": -20.0,
    "rx_grid_max_z": 0.0,
    "rx_grid_step_x": 0.1,
    "rx_grid_step_y": 0.1,
    "rx_grid_step_z": 0.1,
    "tx_power_dBm": 0.0,
    "store_paths": false,
    "wedge_max_distance_m": 3.0,
    "wedge_max_candidates": 8
  },

  "em_solver": {
    "frequency_hz": 2400000000.0,
    "solver_mode": "Coverage"
  },

  "output": {
    "export_paths": true,
    "export_cir": false,
    "export_pdp": false,
    "export_aps": false,
    "export_config_snapshot": false
  },

  "validation": {
    "enable_basic_validation": true,
    "enable_reference_compare": false,
    "run_module1_self_check": false,
    "module1_invalid_transmission_case_file": "configs/app/invalid_transmission_missing_mapping.json",
    "module1_invalid_diffraction_case_file": "configs/app/invalid_diffraction_without_wedge.json",
    "power_tolerance_db": 0.1
  },

  "experiment": {
    "experiment_tag": "meeting_coverage",
    "dataset_tag": "demo"
  },

  "numeric_tolerance": {
    "eps_length": 1.0e-6,
    "eps_angle": 1.0e-6,
    "eps_intersection": 1.0e-7,
    "eps_normal": 1.0e-6,
    "eps_deduplicate": 1.0e-5,
    "eps_power": 1.0e-9,
    "self_hit_ignore_distance": 1.0e-5,
    "visibility_origin_offset": 1.0e-5,
    "visibility_target_shrink": 1.0e-5
  }
}
