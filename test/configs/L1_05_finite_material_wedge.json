{
  "app_runtime": { "mode": "debug", "log_level": "INFO", "run_id": "L1_05_finite_material_wedge" },
  "scene_import": {
    "source_file": "test/scenes/L1_canonical/L1_05_pec_wedge_shared.obj",
    "source_format": "obj",
    "scene_material_map_file": "test/configs/L1_wedge_concrete_map.json"
  },
  "scene_preprocess": { "enable_wedge_build": true, "enable_scene_cache": false, "bvh_leaf_size": 16 },
  "material": { "material_database_file": "test/materials/L1_materials.csv" },
  "antenna": { "source_type": "Ideal", "pattern_file": "", "polarization_file": "" },
  "path_search": {
    "max_path_depth": 3,
    "max_reflection_count": 2,
    "max_transmission_count": 0,
    "max_diffraction_count": 1,
    "max_scattering_count": 0,
    "enable_los": true,
    "max_consecutive_same_interaction": 5,
    "tx_x": 0.0, "tx_y": 2.0, "tx_z": 1.0,
    "rx_x": 4.0, "rx_y": -2.0, "rx_z": 1.0
  },
  "sbr": {
    "enabled": true,
    "trace_profile": "FineChannel",
    "ray_count": 20000,
    "max_ray_depth": 3,
    "max_reflection_count": 1,
    "max_transmission_count": 0,
    "max_diffraction_count": 1,
    "ray_power_threshold_dB": -120.0,
    "rx_sphere_radius_m": 0.08,
    "store_paths": true,
    "deterministic_interaction_split": true,
    "enable_dynamic_rx_radius": true,
    "ray_tube_radius_scale": 0.5,
    "ray_tube_min_radius_m": 0.08,
    "ray_tube_max_radius_m": 0.3,
    "enable_path_dedup": true,
    "enable_path_similarity_pruning": false
  },
  "em_solver": { "frequency_hz": 3500000000.0, "solver_mode": "Precise" },
  "output": { "export_paths": true, "export_cir": true, "export_pdp": true, "export_aps": true, "export_config_snapshot": true },
  "validation": { "enable_basic_validation": true, "enable_reference_compare": false, "run_module1_self_check": false },
  "experiment": { "experiment_tag": "L1_05_material", "dataset_tag": "canonical_finite_conductivity_wedge" }
}
